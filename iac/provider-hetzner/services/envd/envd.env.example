# envd Environment Variables
# Copy to /etc/maxicore/envd.env on PRIMARY (chmod 600).

ENVD_NODE_ID=primary-fsn1
ENVD_LISTEN_HOST=0.0.0.0
ENVD_LISTEN_PORT=49983

# Consul / Nomad
CONSUL_HTTP_TOKEN=
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
NOMAD_TOKEN=
NOMAD_ADDR=http://127.0.0.1:4646

# Object Storage (template assets, sandbox-runtime versions)
AWS_REGION=fsn1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_BUCKET_FC_ENV_PIPELINE=maxicore-orch-fc-env-pipeline
S3_BUCKET_FC_BUSYBOX=maxicore-orch-fc-busybox

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.service.consul:4317
OTEL_RESOURCE_ATTRIBUTES=service.name=envd,service.namespace=maxicore

LOG_LEVEL=info
LOG_FORMAT=json
