# Orchestrator Environment Variables
# Copy to /etc/maxicore/orchestrator.env on PRIMARY (chmod 600).
# Loaded by systemd via EnvironmentFile= directive in orchestrator.service.

# Cluster identity
ORCHESTRATOR_NODE_ID=primary-fsn1
ORCHESTRATOR_REGION=fsn1
ORCHESTRATOR_DATACENTER=fsn1-dc14

# Consul ACL (from cluster-bootstrap secrets)
CONSUL_HTTP_TOKEN=
CONSUL_HTTP_ADDR=http://127.0.0.1:8500

# Nomad ACL
NOMAD_TOKEN=
NOMAD_ADDR=http://127.0.0.1:4646

# Hetzner Object Storage (via aws-S3-compat)
AWS_REGION=fsn1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_BUCKET_FC_KERNELS=maxicore-orch-fc-kernels
S3_BUCKET_FC_VERSIONS=maxicore-orch-fc-versions
S3_BUCKET_FC_ENV_PIPELINE=maxicore-orch-fc-env-pipeline
S3_BUCKET_FC_BUSYBOX=maxicore-orch-fc-busybox

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.service.consul:4317
OTEL_RESOURCE_ATTRIBUTES=service.name=orchestrator,service.namespace=maxicore

# Firecracker
FIRECRACKER_BIN=/opt/firecracker/bin/firecracker
JAILER_BIN=/opt/firecracker/bin/jailer
FC_KERNELS_DIR=/opt/firecracker/kernels
FC_ROOTFS_DIR=/opt/firecracker/rootfs

# Sandbox limits (1:1 Manus M64-M67)
SANDBOX_VCPU_COUNT=6
SANDBOX_MEMORY_MB=3891
SANDBOX_ROOTFS_SIZE_MB=42291
SANDBOX_BOOT_TIMEOUT_MS=2000
WARM_POOL_SIZE=10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
