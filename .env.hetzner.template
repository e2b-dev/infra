# =====================================================================
# Hetzner-Provider — Environment Template
# =====================================================================
# Copy this file to .env (or .env.hetzner) and fill in your values.
# Source it before running terraform: `source .env.hetzner`.
#
# All values are EU-sovereign by default (Falkenstein DE, eu-central zone).
# =====================================================================

# ───────────────────────── Required: Provider selection ─────────────────────────

PROVIDER=hetzner

# ───────────────────────── Required: Hetzner Cloud API ─────────────────────────

# Hetzner Cloud API token (read+write).
# Generate at: https://console.hetzner.cloud → Project → Security → API Tokens
TF_VAR_hetzner_api_token=

# Existing Hetzner Cloud SSH key IDs (comma-separated list).
# Look up at: hcloud ssh-key list  (Format: '[1234567,2345678]')
TF_VAR_hetzner_ssh_key_ids=[]

# ───────────────────────── Required: Hetzner Object Storage (S3-compatible) ─────────────────────────

# Hetzner Object Storage credentials.
# Generate at: https://console.hetzner.cloud → Project → Object Storage → Credentials
TF_VAR_hetzner_object_storage_access_key=
TF_VAR_hetzner_object_storage_secret_key=

# Hetzner Object Storage region. One of: fsn1, nbg1, hel1.
# All EU-sovereign. fsn1 = Falkenstein/DE, nbg1 = Nuremberg/DE, hel1 = Helsinki/FI.
TF_VAR_hetzner_object_storage_region=fsn1

# ───────────────────────── Required: Domain ─────────────────────────

# Primary domain or subdomain for this E2B deployment.
# Example: sandbox.helix12.eu
TF_VAR_domain_name=

# ───────────────────────── Required: Environment & Prefix ─────────────────────────

# Deployment environment: dev | staging | prod
TF_VAR_environment=dev

# Resource name prefix (lowercase, ends with '-').
# Examples: maxicore-, helix-, sandbox-
TF_VAR_prefix=maxicore-

# Object Storage bucket prefix. Empty = derived from prefix.
TF_VAR_bucket_prefix=

# ───────────────────────── Region & Datacenter ─────────────────────────

# Hetzner Cloud region for compute resources.
# Examples: fsn1 (Falkenstein/DE), nbg1 (Nuremberg/DE), hel1 (Helsinki/FI)
TF_VAR_hetzner_region=fsn1

# Hetzner network zone (must contain hetzner_region). Options: eu-central, us-east, us-west, ap-southeast.
TF_VAR_hetzner_network_zone=eu-central

# Default datacenter for compute placement.
TF_VAR_hetzner_datacenter=fsn1-dc14

# ───────────────────────── Required for Robot bare-metal (PRIMARY) ─────────────────────────

# Hetzner vSwitch ID for L2 Cloud↔Robot bridging. 0 = skip Robot integration.
# Look up at: https://robot.hetzner.com/vswitch
TF_VAR_hetzner_vswitch_id=0

# vSwitch VLAN ID (Hetzner range 4000-4091). 4000 matches existing MaxiCore production.
TF_VAR_hetzner_vlan_id=4000

# PRIMARY Robot server ID (existing bare-metal VMM-host). 0 = no Robot adoption.
TF_VAR_primary_robot_id=0

# PRIMARY Robot server public IP (for SSH-based provisioning).
TF_VAR_primary_robot_ip=

# Hetzner Robot user/password (only required when primary_robot_id != 0).
# Format: '#ws+username' / 'password'.
# Generate at: https://robot.hetzner.com/preferences/index → Web service settings
TF_VAR_hetzner_robot_user=
TF_VAR_hetzner_robot_password=

# ───────────────────────── DNS Strategy ─────────────────────────

# DNS provider selection: false = Hetzner DNS (default), true = Cloudflare (legacy).
TF_VAR_use_cloudflare_dns=false

# Hetzner DNS API token. Required when use_cloudflare_dns=false.
# Generate at: https://dns.hetzner.com → API tokens
TF_VAR_hetzner_dns_token=

# Cloudflare API token. Required when use_cloudflare_dns=true.
# Permissions needed: Zone.DNS:Edit, Zone.Zone:Read.
TF_VAR_cloudflare_api_token=

# ───────────────────────── DNS Records (NX.2.2) ─────────────────────────

# Hetzner Cloud Load Balancer hostname (preferred). Set after NX.2.5 LB provisioned.
TF_VAR_lb_hostname=
TF_VAR_lb_ipv4=
TF_VAR_lb_ipv6=
TF_VAR_create_apex_a_record=false

# ───────────────────────── Let's Encrypt / ACME (NX.2.2) ─────────────────────────

# Issue Let's Encrypt wildcard cert via DNS-01 (requires use_cloudflare_dns=false).
TF_VAR_enable_lets_encrypt=true

# Email for Let's Encrypt account registration. Used for expiry notifications.
TF_VAR_acme_email=

# ACME directory URL. Default = Let's Encrypt production.
TF_VAR_acme_server_url=https://acme-v02.api.letsencrypt.org/directory

# Upload issued cert to Hetzner Cloud Certificate store.
TF_VAR_cert_upload_to_hcloud=true

# ───────────────────────── Network CIDRs ─────────────────────────

# Cloud Network CIDR. Default matches existing MaxiCore production.
TF_VAR_cloud_network_cidr=10.0.0.0/8

# Cloud Subnet (within cloud_network_cidr).
TF_VAR_cloud_subnet_cidr=10.0.1.0/24

# vSwitch subnet (for Cloud↔Robot bridging).
TF_VAR_vswitch_subnet_cidr=10.10.0.0/24

# ───────────────────────── Cluster Sizing ─────────────────────────

# Build cluster configuration (JSON).
# Example:
#   {"default": {"cluster_size": 1, "server_type": "cpx41", "boot_disk_gb": 200, "cache_disk_gb": 375}}
TF_VAR_build_clusters_config={"default":{"cluster_size":1,"server_type":"cpx41","boot_disk_gb":200,"cache_disk_gb":375}}

# Client cluster configuration (Firecracker-host pool).
# Example:
#   {"default": {"cluster_size": 1, "server_type": "ccx33", "hugepages_percentage": 80, "boot_disk_gb": 200, "cache_disk_gb": 375}}
TF_VAR_client_clusters_config={"default":{"cluster_size":1,"server_type":"ccx33","hugepages_percentage":80,"boot_disk_gb":200,"cache_disk_gb":375}}

# API server pool sizing.
TF_VAR_api_cluster_size=1
TF_VAR_api_server_type=cpx41

# ClickHouse pool sizing.
TF_VAR_clickhouse_cluster_size=1
TF_VAR_clickhouse_server_type=cpx41

# Ingress count (Hetzner Cloud LB is regional, usually 1).
TF_VAR_ingress_count=1

# Client-proxy count.
TF_VAR_client_proxy_count=1

# Redis: managed = separate Cloud Server, false = Nomad job.
TF_VAR_redis_managed=false
TF_VAR_redis_server_type=cx22
TF_VAR_redis_replica_size=0

# ───────────────────────── Sandbox Firewall ─────────────────────────

# Internal CIDRs that sandboxes are allowed to reach (comma-separated → list).
# Empty = full deny on private ranges except link-local + DNS.
TF_VAR_allow_sandbox_internal_cidrs=[]

# ───────────────────────── Optional ─────────────────────────

# Allow force-destroy of all resources (set to true for dev only!).
TF_VAR_allow_force_destroy=false

# ───────────────────────── Terraform Backend (Hetzner Object Storage) ─────────────────────────
# These are read by terraform init -backend-config=...
# Pre-create the bucket via Hetzner Console before first init.

TF_BACKEND_BUCKET=maxicore-tfstate
TF_BACKEND_ENDPOINT=https://fsn1.your-objectstorage.com
TF_BACKEND_REGION=fsn1
TF_BACKEND_ACCESS_KEY=$TF_VAR_hetzner_object_storage_access_key
TF_BACKEND_SECRET_KEY=$TF_VAR_hetzner_object_storage_secret_key
