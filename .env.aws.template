# ------------------------------------------- Required block -----------------------------------------------------------
# These variables are required and don't have default values
# You must provide values for these to run the deployment successfully

AWS_PROFILE=
AWS_ACCOUNT_ID=
AWS_REGION=

# your domain or subdomain name, eg great-innovations.dev, e2b.great-innovations.dev
DOMAIN_NAME=

# OIDC verifier config used by API to validate client-proxy OAuth tokens
CLIENT_PROXY_OIDC_ISSUER_URL=
CLIENT_PROXY_OIDC_AUDIENCE=

# OAuth client credentials used by client-proxy to call public API gRPC
API_GRPC_OAUTH_CLIENT_ID=
API_GRPC_OAUTH_CLIENT_SECRET=
API_GRPC_OAUTH_TOKEN_URL=

# ------------------------------------------- Required with defaults ---------------------------------------------------
# These variables need to be specified but have default values

PROVIDER=aws
# prefix identifier for all resources
PREFIX=e2b-

# prod, staging, dev
TERRAFORM_ENVIRONMENT=dev
